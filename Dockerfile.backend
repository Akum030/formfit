FROM node:20-slim AS base
WORKDIR /app

# Install dependencies
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev

# Copy prisma schema and generate client
COPY prisma ./prisma
RUN npx prisma generate

# Copy compiled code
COPY dist ./dist

EXPOSE 4000
ENV NODE_ENV=production
CMD ["node", "dist/index.js"]
