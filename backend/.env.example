# Server
PORT=4000

# Database (PostgreSQL or SQLite for local dev)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/ai_gym_trainer"

# Google Gemini / Vertex AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_NAME=gemini-2.0-flash

# Sarvam AI – Voice (STT + TTS)
SARVAM_API_KEY=your-sarvam-api-key-here
SARVAM_STT_ENDPOINT=https://api.sarvam.ai/speech-to-text
SARVAM_TTS_ENDPOINT=https://api.sarvam.ai/text-to-speech

# Optional: GCP for Vertex AI (alternative to Gemini API key)
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=us-central1
